{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "google/gemma-4-31b-it",
      "prompt_append": "You are the master orchestrator. Be extremely concise. No preamble, no flattery, no status updates. PROACTIVELY manage context using the `context-master` skill and `ctx_reduce` to maintain headroom < 80%. ALWAYS load specialized skills via the `skill` tool before starting non-trivial work. Delegate implementation to `deep` or `unspecified-high` agents in parallel.",
      "fallback_models": [
        "opencode/nemotron3-super-free",
        "opencode/minimax-m2.5-free"
      ],
      "temperature": 0.1,
      "variant": "max",
      "ultrawork": {
        "model": "google/gemma-4-31b-it",
        "fallback_models": [
          "opencode/nemotron3-super-free",
          "opencode/minimax-m2.5-free"
        ],
        "variant": "max"
      }
    },
    "sisyphus-junior": {
      "model": "google/gemma-4-31b-it",
      "skills": ["context-master"]
    },
    "hephaestus": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "variant": "high",
      "reasoningEffort": "high"
    },
    "oracle": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": ["opencode/minimax-m2.5-free"],
      "variant": "high",
      "temperature": 0.1,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 8192
      },
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "prometheus": {
      "model": "google/gemma-4-31b-it",
      "prompt_append": "When planning, explicitly identify which specialized skills (e.g., `security-audit`, `modern-ui-ux`) should be loaded by the orchestrator to ensure senior-level execution.",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "temperature": 0.1
    },
    "metis": {
      "model": "google/gemma-4-31b-it",
      "prompt_append": "When analyzing requests, identify the need for specialized skills (e.g., `security-audit`, `modern-ui-ux`) and suggest them to the orchestrator to avoid generic AI slop.",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "temperature": 0.3
    },
    "momus": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "variant": "xhigh",
      "temperature": 0.1
    },
    "atlas": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "google/gemini-3.1-flash-lite-preview",
        "opencode/minimax-m2.5-free"
      ],
      "temperature": 0.1
    },
    "explore": {
      "model": "opencode/ling2.6-flash-free",
      "fallback_models": ["opencode/minimax-m2.5-free"],
      "temperature": 0.1
    },
    "librarian": {
      "model": "opencode/ling2.6-flash-free",
      "fallback_models": ["opencode/minimax-m2.5-free"],
      "temperature": 0.1
    },
    "multimodal-looker": {
      "model": "opencode/ling2.6-flash-free",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "temperature": 0.1
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "opencode/nemotron3-super-free",
        "google/gemini-3.1-flash-lite-preview"
      ]
    },
    "deep": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/nemotron3-super-free",
        "opencode/minimax-m2.5-free"
      ]
    },
    "ultrabrain": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/nemotron3-super-free",
        "opencode/minimax-m2.5-free"
      ]
    },
    "artistry": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/nemotron3-super-free",
        "opencode/minimax-m2.5-free"
      ]
    },
    "quick": {
      "model": "opencode/ling2.6-flash-free"
    },
    "unspecified-low": {
      "model": "opencode/ling2.6-flash-free"
    },
    "unspecified-high": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "opencode/nemotron3-super-free",
        "google/gemini-3.1-flash-lite-preview"
      ]
    },
    "writing": {
      "model": "google/gemma-4-31b-it"
    }
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "background_task": {
    "defaultConcurrency": 3,
    "providerConcurrency": {
      "google": 3,
      "opencode": 5,
      "anthropic": 3,
      "openai": 3
    }
  },
  "disabled_hooks": [
    "context-window-monitor",
    "preemptive-compaction",
    "anthropic-context-window-limit-recovery"
  ]
}
