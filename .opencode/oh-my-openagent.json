{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "google/gemma-4-31b-it",
      "prompt_append": "You are the master orchestrator. PROACTIVELY manage context using the `context-master` skill and `ctx_reduce` to maintain headroom < 80%. ALWAYS load specialized skills via the `skill` tool before starting non-trivial work. Delegate implementation to `deep` or `unspecified-high` agents in parallel.",
      "fallback_models": [
        "opencode/nemotron3-super-free",
        "opencode/minimax-m2.5-free"
      ],
      "temperature": 0.1,
      "variant": "max",
      "ultrawork": {
        "model": "google/gemma-4-31b-it",
        "fallback_models": [
          "opencode/nemotron3-super-free",
          "opencode/minimax-m2.5-free"
        ],
        "variant": "max"
      },
      "skills": [
        "skill-creator",
        "stack-advisor",
        "perf-optimizer",
        "security-audit",
        "api-documentation",
        "laravel-inertia-react",
        "laravel-saas",
        "docker-dev",
        "pest-testing",
        "database-pgsql",
        "redis-queue",
        "api-rest",
        "reverb-websocket",
        "eloquent-queries",
        "filament-admin",
        "memory-helper",
        "context-master",
        "git-ops",
        "css-master",
        "modern-ui-ux"
      ]
    },
    "sisyphus-junior": {
      "model": "google/gemma-4-31b-it",
      "skills": ["context-master"]
    },
    "hephaestus": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "variant": "high",
      "reasoningEffort": "high",
      "skills": [
        "laravel-inertia-react",
        "laravel-saas",
        "eloquent-queries",
        "api-rest",
        "redis-queue",
        "git-ops",
        "pest-testing",
        "docker-dev",
        "security-audit",
        "perf-optimizer"
      ]
    },
    "oracle": {
      "model": "google/gemma-4-31b-it",
      "skills": ["stack-advisor", "security-audit"],
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "variant": "high",
      "temperature": 0.1,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 8192
      },
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "prometheus": {
      "model": "google/gemma-4-31b-it",
      "prompt_append": "When planning, explicitly identify which specialized skills (e.g., `security-audit`, `modern-ui-ux`) should be loaded by the orchestrator to ensure senior-level execution.",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "temperature": 0.1,
      "skills": ["skill-creator", "stack-advisor"]
    },
    "metis": {
      "model": "google/gemma-4-31b-it",
      "prompt_append": "When analyzing requests, identify the need for specialized skills (e.g., `security-audit`, `modern-ui-ux`) and suggest them to the orchestrator to avoid generic AI slop.",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "temperature": 0.3,
      "skills": ["stack-advisor"]
    },
    "momus": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/minimax-m2.5-free",
        "google/gemini-3.1-flash-lite-preview"
      ],
      "variant": "xhigh",
      "temperature": 0.1,
      "skills": ["skill-creator"]
    },
    "atlas": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "google/gemini-3.1-flash-lite-preview",
        "opencode/minimax-m2.5-free"
      ],
      "temperature": 0.1,
      "skills": ["skill-creator", "stack-advisor", "git-ops", "memory-helper"]
    },
    "explore": {
      "model": "opencode/ling2.6-flash-free",
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ],
      "temperature": 0.1
    },
    "librarian": {
      "model": "opencode/ling2.6-flash-free",
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ],
      "temperature": 0.1
    },
    "multimodal-looker": {
      "model": "google/gemini-3.1-flash-lite-preview",
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ],
      "temperature": 0.1
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-flash-lite-preview"
    },
    "deep": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/nemotron3-super-free",
        "opencode/minimax-m2.5-free"
      ]
    },
    "ultrabrain": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/nemotron3-super-free",
        "opencode/minimax-m2.5-free"
      ]
    },
    "artistry": {
      "model": "google/gemma-4-31b-it",
      "fallback_models": [
        "opencode/nemotron3-super-free",
        "opencode/minimax-m2.5-free"
      ]
    },
    "quick": {
      "model": "opencode/minimax-m2.5-free"
    },
    "unspecified-low": {
      "model": "opencode/minimax-m2.5-free"
    },
    "unspecified-high": {
      "model": "opencode/nemotron3-super-free",
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ]
    },
    "writing": {
      "model": "opencode/minimax-m2.5-free"
    }
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "background_task": {
    "defaultConcurrency": 3,
    "providerConcurrency": {
      "google": 5,
      "opencode": 5,
      "anthropic": 3,
      "openai": 3
    }
  },
  "disabled_hooks": [
    "context-window-monitor",
    "preemptive-compaction",
    "anthropic-context-window-limit-recovery"
  ]
}
